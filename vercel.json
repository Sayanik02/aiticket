{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "http://fr.glitchnode.cloud:25577/api/:path*"
    },
    {
      "source": "/transcripts/:path*",
      "destination": "http://fr.glitchnode.cloud:25577/transcripts/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
